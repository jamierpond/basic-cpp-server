FROM ubuntu:22.04

# Install dependencies including modern Clang and Ninja
RUN apt-get update && apt-get install -y \
    git \
    lsb-release \
    wget \
    software-properties-common \
    gnupg \
    ninja-build \
    entr \
    && rm -rf /var/lib/apt/lists/*


# Install up to date CMake
RUN wget -O - https://apt.kitware.com/keys/kitware-archive-latest.asc | apt-key add - && \
    apt-add-repository 'deb https://apt.kitware.com/ubuntu/ $(lsb_release -cs) main' && \
    apt-get update && \
    apt-get install -y cmake && \
    rm -rf /var/lib/apt/lists/*


# Add LLVM/Clang repository and install Clang 16
RUN wget -O - https://apt.llvm.org/llvm-snapshot.gpg.key | apt-key add - && \
    add-apt-repository "deb http://apt.llvm.org/$(lsb_release -cs)/ llvm-toolchain-$(lsb_release -cs)-16 main" && \
    apt-get update && \
    apt-get install -y clang-16 lldb-16 lld-16 libc++-16-dev libc++abi-16-dev && \
    rm -rf /var/lib/apt/lists/*

# Set Clang as the default compiler
ENV CC=clang-16
ENV CXX=clang++-16

# Set working directory
WORKDIR /app

# Copy watch script (source code will be volume-mounted)
COPY scripts/watch.sh /app/scripts/watch.sh
RUN chmod +x /app/scripts/watch.sh
COPY CMakePresets.json /app/CMakePresets.json

RUN cmake --preset docker

# Run the watch script
CMD ["/app/scripts/watch.sh"]

